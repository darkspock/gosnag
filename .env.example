# Required
DATABASE_URL=postgres://gosnag:gosnag@localhost:5432/gosnag?sslmode=disable
GOOGLE_CLIENT_ID=your-google-client-id

# Optional - Server
PORT=8080
LOG_LEVEL=info
BASE_URL=http://localhost:8080
SESSION_SECRET=change-me-to-a-random-string
CORS_ALLOWED_ORIGINS=

# Optional - Issue resolution
DEFAULT_COOLDOWN_MINUTES=30

# Optional - Event retention (days, 0 = keep forever)
EVENT_RETENTION_DAYS=90

# Optional - Rate limiting (requests per minute per IP, 0 = unlimited)
INGEST_RATE_LIMIT_PER_MIN=0

# Optional - Email alerts (SMTP)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=gosnag@localhost

# Optional - Slack alerts
SLACK_WEBHOOK_URL=
